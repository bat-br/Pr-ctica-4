<Window x:Class="GestorProductosWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestorProductosWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="0,0,0,-6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="39*"/>
            <ColumnDefinition Width="361*"/>
        </Grid.ColumnDefinitions>
        <TabControl Grid.ColumnSpan="2" Margin="0,0,0,10">
            <TabItem Header="Inventario">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="#FF880D0D" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid Background="#FF34CFDA">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="111*"/>
                        <ColumnDefinition Width="683*"/>
                    </Grid.ColumnDefinitions>
                    <DataGrid x:Name="dataGridProductos" d:ItemsSource="{d:SampleData ItemCount=5}" Grid.ColumnSpan="2">
                        <DataGrid.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="Black"/>
                                <GradientStop Color="#FFF3F3F3" Offset="1"/>
                            </LinearGradientBrush>
                        </DataGrid.Background>
                    </DataGrid>
                    <Button x:Name="btnAgregar" Grid.Column="1" Content="Agregar" HorizontalAlignment="Left" Margin="520,212,0,0" VerticalAlignment="Top" Height="46" Width="137" Click="btnAgregar_Click" Background="#FFD6D0D0"/>
                    <Button x:Name="btnEliminar" Content="Eliminar" HorizontalAlignment="Left" Margin="26,201,0,0" VerticalAlignment="Top" Grid.ColumnSpan="2" Height="57" Width="156" Click="btnEliminar_Click"/>
                    <Image Grid.Column="1" HorizontalAlignment="Left" Height="184" Margin="375,131,0,0" VerticalAlignment="Top" Width="284" Source="/Spiderman.png" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform Angle="1.034"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <Image Grid.Column="1" HorizontalAlignment="Left" Height="163" Margin="49,212,0,0" VerticalAlignment="Top" Width="254" Source="/DosSpiderman2.png"/>
                </Grid>
            </TabItem>
            <TabItem Header="Busqueda">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="#FF36C338" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="Black"/>
                            <GradientStop Color="#FF00FFCA" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="19*"/>
                        <ColumnDefinition Width="23*"/>
                        <ColumnDefinition Width="121*"/>
                        <ColumnDefinition Width="629*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="comboTipoBusqueda" Grid.Column="4" HorizontalAlignment="Left" Margin="78,20,0,0" VerticalAlignment="Top" Width="491" Height="34"/>
                    <TextBox x:Name="txtBusqueda" Grid.Column="4" HorizontalAlignment="Left" Margin="78,59,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="491" Height="55"/>
                    <Button x:Name="btnBuscar" Grid.Column="4" Content="Buscar" HorizontalAlignment="Left" Margin="422,119,0,0" VerticalAlignment="Top" Height="35" Width="147" Click="btnBuscar_Click"/>
                    <TextBlock x:Name="txtResultadoBusqueda" Grid.Column="4" HorizontalAlignment="Left" Margin="78,180,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Top" Height="135" Width="491"/>
                    <ProgressBar x:Name="iteraciones" Grid.Column="3" HorizontalAlignment="Left" Height="42" Margin="78,330,0,0" VerticalAlignment="Top" Width="662" Grid.ColumnSpan="2"/>
                    <Image Grid.Column="1" HorizontalAlignment="Left" Height="145" Margin="10,10,0,0" VerticalAlignment="Top" Width="204" Source="/images.jpg" Grid.ColumnSpan="4"/>
                    <Image Grid.Column="2" Grid.ColumnSpan="3" HorizontalAlignment="Left" Height="156" Margin="0,159,0,0" VerticalAlignment="Top" Width="193" Source="/images (1).jpg"/>
                </Grid>
            </TabItem>
            <TabItem Header="Ordenamiento">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="#FF04ABCA" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid>
                    <Grid.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="Black"/>
                            <GradientStop Color="#FF94FF00" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="7*"/>
                        <ColumnDefinition Width="88*"/>
                        <ColumnDefinition Width="695*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="comboCriterioOrden" HorizontalAlignment="Left" Margin="179,10,0,0" VerticalAlignment="Top" Width="468" Height="41" Grid.Column="3"/>
                    <Button x:Name="btnOrdenar" Content="Ordenar" HorizontalAlignment="Left" Margin="406,74,0,0" VerticalAlignment="Top" Height="51" Width="241" Click="btnOrdenar_Click" Grid.Column="3"/>
                    <ListView x:Name="listViewOrdenados" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="25,187,509,53" Grid.ColumnSpan="2" Grid.Column="2">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Canvas x:Name="canvasGrafico" Margin="234,141,48,53" Grid.Column="3">
                        <Rectangle Height="136" Canvas.Left="10" Stroke="Black" Canvas.Top="36" Width="41" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    </Canvas>
                    <Image Grid.Column="2" HorizontalAlignment="Left" Height="172" Margin="79,10,0,0" VerticalAlignment="Top" Width="212" Source="/Hackerman.jpg" Grid.ColumnSpan="2"/>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
